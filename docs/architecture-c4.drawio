  <!-- ============================================================ -->
  <!-- PAGE 4 — RUNTIME / DYNAMIC VIEW                              -->
  <!-- output first, then eval+verification decides re-loop/abstain/accept -->
  <!-- ============================================================ -->
  <diagram id="runtime-dag" name="4 · Runtime (answer + verify loop)">
    <mxGraphModel dx="1000" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="p4_title" value="Runtime View — POST /api/chat/auditable-rag: produce an answer, then verify and re-loop if needed" style="text;html=1;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="d_rails_in" value="Input + Dialog guardrails" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="70" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d_retrieval" value="1 · retrieval&#10;dense + BM25 + rerank (local embeddings)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="330" y="140" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d_classifier" value="2 · classifier&#10;numeric vs qualitative" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="220" width="260" height="50" as="geometry" />
        </mxCell>

        <!-- numeric branch -->
        <mxCell id="d_extraction" value="3a · extraction&#10;pull XBRL facts for the asked metrics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="310" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d_math" value="4a · math&#10;Python does all arithmetic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="120" y="390" width="230" height="50" as="geometry" />
        </mxCell>

        <!-- qualitative branch -->
        <mxCell id="d_qual" value="3b · qualitative answer&#10;LLM over retrieved docs&#10;(+ sentiment / tone)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="590" y="310" width="260" height="130" as="geometry" />
        </mxCell>

        <!-- draft output (merge point) -->
        <mxCell id="d_output" value="5 · draft output&#10;candidate answer assembled" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="490" width="280" height="56" as="geometry" />
        </mxCell>

        <!-- eval + verification AFTER output (the loop controller) -->
        <mxCell id="d_verify" value="6 · eval + verification&#10;XBRL cross-check (1%) + NLI entailment + confidence&#10;→ decides: accept · re-loop · abstain" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="310" y="580" width="320" height="72" as="geometry" />
        </mxCell>
        <mxCell id="d_abstain" value="abstain&#10;(fail · no retries left)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="690" y="588" width="200" height="56" as="geometry" />
        </mxCell>

        <!-- accept -> lineage AFTER verification passes -->
        <mxCell id="d_lineage" value="7 · build_lineage&#10;assemble the audit trail for the accepted answer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="690" width="280" height="56" as="geometry" />
        </mxCell>
        <mxCell id="d_rails_out" value="8 · Output guardrails (PII mask)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="780" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d_response" value="Response&#10;answer · sources · xbrl_facts · verification badge · math_steps · what_it_means · follow_ups · confidence · lineage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="860" width="360" height="90" as="geometry" />
        </mxCell>

        <!-- edges -->
        <mxCell id="d_e0" style="endArrow=block;html=1;rounded=1;" edge="1" parent="1" source="d_rails_in" target="d_retrieval"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d_e1" style="endArrow=block;html=1;rounded=1;" edge="1" parent="1" source="d_retrieval" target="d_classifier"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d_e2" value="numeric" style="endArrow=block;html=1;rounded=1;fontSize=9;" edge="1" parent="1" source="d_classifier" target="d_extraction"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d_e3" value="qualitative" style="endArrow=block;html=1;rounded=1;fontSize=9;" edge="1" parent="1" source="d_classifier" target="d_qual"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d_e4" style="endArrow=block;html=1;rounded=1;" edge="1" parent="1" source="d_extraction" target="d_math"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d_e5" style="endArrow=block;html=1;rounded=1;" edge="1" parent="1" source="d_math" target="d_output"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d_e6" style="endArrow=block;html=1;rounded=1;" edge="1" parent="1" source="d_qual" target="d_output"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d_e7" style="endArrow=block;html=1;rounded=1;" edge="1" parent="1" source="d_output" target="d_verify"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- re-loop back to retrieval -->
        <mxCell id="d_e8" value="re-loop&#10;(fail · retries left)" style="endArrow=block;html=1;rounded=1;fontSize=9;strokeColor=#b85450;fontColor=#b85450;dashed=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="d_verify" target="d_retrieval">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="60" y="616" />
              <mxPoint x="60" y="165" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="d_e9" value="fail · no retries" style="endArrow=block;html=1;rounded=1;fontSize=9;" edge="1" parent="1" source="d_verify" target="d_abstain"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d_e10" value="accept" style="endArrow=block;html=1;rounded=1;fontSize=9;" edge="1" parent="1" source="d_verify" target="d_lineage"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d_e11" style="endArrow=block;html=1;rounded=1;" edge="1" parent="1" source="d_abstain" target="d_lineage"><mxGeometry relative="1" as="geometry">
          <Array as="points"><mxPoint x="790" y="718" /><mxPoint x="610" y="718" /></Array>
        </mxGeometry></mxCell>
        <mxCell id="d_e12" style="endArrow=block;html=1;rounded=1;" edge="1" parent="1" source="d_lineage" target="d_rails_out"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d_e13" style="endArrow=block;html=1;rounded=1;" edge="1" parent="1" source="d_rails_out" target="d_response"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>


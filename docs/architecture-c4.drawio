        <mxCell id="p3_revdb" value="Runtime Store&#10;review_queue.duckdb" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#9C4DCC;fontColor=#ffffff;strokeColor=#6A1B9A;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1110" y="720" width="170" height="80" as="geometry" />

        <mxCell id="p3_r11" value="reads [SQL]" style="endArrow=open;html=1;dashed=1;fontSize=9;endFill=0;" edge="1" parent="1" source="p3_retriever" target="p3_ragdb"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="p3_r1" value="validates" style="endArrow=open;html=1;dashed=1;fontSize=9;endFill=0;" edge="1" parent="1" source="p3_routes" target="p3_rails"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_r2" value="runs" style="endArrow=open;html=1;dashed=1;fontSize=9;endFill=0;" edge="1" parent="1" source="p3_routes" target="p3_orchestrator"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_r3" value="routes via" style="endArrow=open;html=1;dashed=1;fontSize=9;endFill=0;" edge="1" parent="1" source="p3_orchestrator" target="p3_router"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_r4" value="retrieves" style="endArrow=open;html=1;dashed=1;fontSize=9;endFill=0;" edge="1" parent="1" source="p3_orchestrator" target="p3_retriever"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_r5" value="extracts facts" style="endArrow=open;html=1;dashed=1;fontSize=9;endFill=0;" edge="1" parent="1" source="p3_orchestrator" target="p3_extract"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_r6" value="computes" style="endArrow=open;html=1;dashed=1;fontSize=9;endFill=0;" edge="1" parent="1" source="p3_orchestrator" target="p3_calc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3_r7" value="builds trail" style="endArrow=open;html=1;dashed=1;fontSize=9;endFill=0;" edge="1" parent="1" source="p3_orchestrator" target="p3_lineage"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- app -> governance service (the key call) -->
        <mxCell id="p3_r8" value="verify answer&#10;[HTTP]" style="endArrow=open;html=1;dashed=1;fontSize=9;endFill=0;fontStyle=1;strokeColor=#6A1B9A;fontColor=#6A1B9A;" edge="1" parent="1" source="p3_orchestrator" target="p3_numverify"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- external/store edges -->
        <mxCell id="p3_r9" value="generation" style="endArrow=open;html=1;dashed=1;fontSize=9;endFill=0;" edge="1" parent="1" source="p3_orchestrator" target="p3_llm"><mxGeometry relative="1" as="geometry" /></mxCell>
